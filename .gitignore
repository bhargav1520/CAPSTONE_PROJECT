# .gitignore

# Exclude datasets folder (large files)
Datasets/

# Generated output files (synthetic load, weather data, results)
outputs/monthly_synthetic_*.csv
outputs/weather_irradiance_*.csv
results/optimization_result_*.json

# Byte-compiled / cache
__pycache__/
*.py[cod]

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Output and results (optional, comment out if you want to keep these tracked)
# outputs/
# results/

# OS files
.DS_Store
Thumbs.db

# VS Code settings
.vscode/
